LITELLM_MODEL=
OPENAI_API_KEY=
GEMINI_API_KEY=

# デバイス名は部分一致で検索されます（例: "Voicemeeter", "Focusrite" など）
# 指定がない（空の）場合は AUDIO_INPUT_DEVICE_INDEX が使用されます
AUDIO_INPUT_DEVICE_NAME=
AUDIO_INPUT_DEVICE_INDEX=

# 出力側も同様に部分一致で検索されます
AUDIO_OUTPUT_DEVICE_NAME=
AUDIO_OUTPUT_DEVICE_INDEX=

# 会話履歴として保持する最大トークン数（デフォルト: 4000）
MAX_HISTORY_TOKENS=4000
